define rawMeasurements = [42, 17, 42, 89, 17, 23, 89, 90, 42];
define uniqueCollection = [];
for item in rawMeasurements {
    define found = false;
    for uniqueItem in uniqueCollection {
        if (item == uniqueItem) {
            found = true;
        }
    }
    if (!found) {
        push(uniqueCollection, item);
    }
}

show("Unique Set Unsorted: " + str(uniqueCollection));
define cleanedSorted = sort(uniqueCollection);
show("Unique Set Cleaned & Sorted: " + str(cleanedSorted));
